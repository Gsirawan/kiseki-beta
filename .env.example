# Kiseki configuration
# Copy to .env and uncomment to override defaults

# Core
# OLLAMA_HOST=localhost:11434
# KISEKI_DB=kiseki.db
# EMBED_MODEL=qwen3-embedding:4b
# EMBED_DIM=2560
# USER_ALIAS=User
# ASSISTANT_ALIAS=Assistant
# KISEKI_ALIASES=

# Encryption (AES-256 at rest via SQLCipher)
# Requires building with: go build -tags "fts5,libsqlite3" and SQLCipher linked.
# If unset, database is plaintext (no encryption).
# To encrypt an existing database: kiseki encrypt --confirm
# KISEKI_DB_KEY=

# Tool Naming (prefix for all MCP tool names)
# KISEKI_PREFIX=kiseki

# Mail System (inter-agent messaging)
# KISEKI_MAIL_IDENTITY=
# KISEKI_MAIL_PEERS=
# KISEKI_MAIL_DIR=

# Entity Graph (semantic alias expansion in search)
# KISEKI_ENTITIES=

# Typo Normalization (watcher hook)
# KISEKI_TYPOS=

# Text Backup (safety net during watch)
# KISEKI_BACKUP_DIR=

# Note Extraction (auto-save subagent outputs as markdown files)
# KISEKI_NOTES_DIR=
# KISEKI_NOTES_AGENT=
