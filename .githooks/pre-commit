#!/usr/bin/env bash
# pre-commit: personal data leak scanner
# Install: git config core.hooksPath .githooks
# Skip (emergency only): SKIP_LEAK_CHECK=1 git commit

set -euo pipefail

# ─── Emergency skip ────────────────────────────────────────────────────────────
if [[ "${SKIP_LEAK_CHECK:-0}" == "1" ]]; then
    echo "WARNING: leak check skipped via SKIP_LEAK_CHECK=1 — you are responsible for this commit." >&2
    exit 0
fi

# ─── Helpers ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

fail() {
    echo -e "${RED}[LEAK BLOCKED]${NC} $*" >&2
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $*" >&2
}

# ─── Collect staged files ──────────────────────────────────────────────────────
# Only look at files that exist in the index (not deletions)
mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM)

if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
    exit 0
fi

# ─── Allowlist: files that are exempt from pattern scanning ────────────────────
is_allowed_file() {
    local file="$1"
    case "$file" in
        # Example/template files — expected to reference real-looking paths as stubs
        *.example | *.example.* | *example* ) return 0 ;;
        # Documentation — generic paths used as illustration
        README.md | readme.md | LICENSE | COPYING ) return 0 ;;
        docs/* | doc/* | *.md ) return 0 ;;
        # Test fixtures — fake values by design
        *_test.go | *_test.py | testdata/* | test/* | tests/* ) return 0 ;;
        # This hook itself
        .githooks/pre-commit ) return 0 ;;
    esac
    return 1
}

# ─── Pattern definitions ───────────────────────────────────────────────────────
# Each entry: "LABEL|REGEX"
# Regex must not contain a pipe character (use [|] if needed).
PATTERNS=(
    # Personal / deployment filesystem paths
    "personal-path:/root/"
    "personal-path:/home/maximus/"
    "personal-path:/mnt/office/"

    # Known VPS IP
    "vps-ip:46\.202\.130\.107"

    # Personal domains (matched as hostnames, not just substrings)
    "personal-domain:deepnode\.me"

    # Gitea / private repo URLs
    "private-repo:git\.deepnode\.me"

    # Telegram bot token format: digits:AAH...
    "telegram-token:[0-9]{7,12}:AAH[A-Za-z0-9_-]{30,}"

    # Hardcoded secret assignments with actual values
    # Matches: key=<non-empty-value> but NOT key= or key=your-key-here or key=<placeholder>
    # Excludes lines where value is a shell variable reference ($VAR) or a placeholder hint
    "hardcoded-password:(?i)password\s*=\s*(?!\s*$)(?!\$)(?!your-)(?!<)[A-Za-z0-9!@#%^&*()_+=-]{6,}"
    "hardcoded-api-key:(?i)api[_-]?key\s*=\s*(?!\s*$)(?!\$)(?!your-)(?!<)[A-Za-z0-9_/+=-]{10,}"
    "hardcoded-token:(?i)\btoken\s*=\s*(?!\s*$)(?!\$)(?!your-)(?!<)[A-Za-z0-9_/+=-]{10,}"
    "hardcoded-secret:(?i)\bsecret\s*=\s*(?!\s*$)(?!\$)(?!your-)(?!<)[A-Za-z0-9_/+=-]{10,}"

    # Actual .env key=value lines with real content (not placeholder lines)
    "env-db-key:KISEKI_DB_KEY\s*=\s*(?!\s*$)(?!your-)(?!<)[A-Za-z0-9_/+=-]{6,}"

    # Personal names appearing in code (not in comments or doc strings)
    # These match the bare names as identifiers, not inside comment lines
    "personal-name-ghaith:\bGhaith\b"
    "personal-name-sirawan:\bSirawan\b"
    "personal-name-nadia:\bNadia\b"
)

# ─── Scan ──────────────────────────────────────────────────────────────────────
FOUND_LEAK=0

for file in "${STAGED_FILES[@]}"; do
    if is_allowed_file "$file"; then
        continue
    fi

    # Get the staged content (not the working tree content)
    # --unified=0 gives only changed lines with no context, prefix + means added line
    staged_diff=$(git diff --cached --unified=0 -- "$file" 2>/dev/null || true)
    if [[ -z "$staged_diff" ]]; then
        continue
    fi

    # Extract only added lines (lines starting with + but not the diff header +++)
    added_lines=$(printf '%s\n' "$staged_diff" | grep -P '^\+(?!\+\+)' | sed 's/^\+//' || true)
    if [[ -z "$added_lines" ]]; then
        continue
    fi

    for pattern_entry in "${PATTERNS[@]}"; do
        label="${pattern_entry%%:*}"
        regex="${pattern_entry#*:}"

        # For personal-name patterns: skip comment lines (lines starting with optional
        # whitespace then // # -- /* *)
        if [[ "$label" == personal-name-* ]]; then
            check_lines=$(printf '%s\n' "$added_lines" \
                | grep -vP '^\s*(//|#|--|/\*|\*)' || true)
        else
            check_lines="$added_lines"
        fi

        if [[ -z "$check_lines" ]]; then
            continue
        fi

        match=$(printf '%s\n' "$check_lines" | grep -P "$regex" | head -3 || true)
        if [[ -n "$match" ]]; then
            fail "Pattern '$label' matched in staged file: $file"
            while IFS= read -r line; do
                echo "    > $line" >&2
            done <<< "$match"
            FOUND_LEAK=1
        fi
    done
done

# ─── Result ────────────────────────────────────────────────────────────────────
if [[ "$FOUND_LEAK" -eq 1 ]]; then
    echo >&2
    echo "── How to fix ──────────────────────────────────────────────────────────" >&2
    echo "  1. Remove or replace the personal data in the flagged file(s)." >&2
    echo "  2. Re-stage the file: git add <file>" >&2
    echo "  3. Retry the commit." >&2
    echo >&2
    echo "  If the match is a false positive, add the file to the allowlist in" >&2
    echo "  .githooks/pre-commit (is_allowed_file function) and document why." >&2
    echo >&2
    echo "  Emergency bypass (use only if you are certain this is safe):" >&2
    echo "    SKIP_LEAK_CHECK=1 git commit ..." >&2
    echo "────────────────────────────────────────────────────────────────────────" >&2
    exit 1
fi

exit 0
